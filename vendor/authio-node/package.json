{
  "name": "@useauthio/node",
  "version": "0.1.0",
  "description": "Authio server-side SDK for Node.js, Bun, Deno, and edge runtimes. Vendored copy bundled with @useauthio/widgets so it resolves locally without a separate install.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/authio-com/authio_node.git"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "jose": "^5.9.0"
  },
  "engines": {
    "node": ">=20"
  }
}
